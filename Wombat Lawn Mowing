    <footer>

        <p>&copy; 2026 GreenWave Atlantic • Bridgehampton, NY • (631) 324-4339</p>

        <p>Full-Service Landscaping • Sustainable Practices • Hamptons East End</p>

    </footer>



    <div class="floating-cta">

        <i class="fas fa-phone"></i> (631) 324-4339

    </div>



    <script>

        // Smooth scroll

        document.querySelectorAll('a[href^="#"]').forEach(anchor => {

            anchor.addEventListener('click', function(e) {

                if (this.getAttribute('href') !== '#') {

                    e.preventDefault();

                    document.querySelector(this.getAttribute('href')).scrollIntoView({ behavior: 'smooth' });

                }

            });

        });

    </script>

</body>

</html>
