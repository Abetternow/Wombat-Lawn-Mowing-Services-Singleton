<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>GreenWave Atlantic | Professional Landscaping in the Hamptons</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>

        :root {

            --green: #2e7d32;

            --dark: #1b3a1f;

            --light: #f8f9f6;

            --accent: #4caf50;

        }

        * { margin:0; padding:0; box-sizing:border-box; }

        body { font-family: system-ui, -apple-system, BlinkMacSystemFont, sans-serif; line-height:1.6; color:#333; background:var(--light); }

        header {

            position:fixed; top:0; width:100%; background:rgba(255,255,255,0.97); z-index:1000;

            padding:1rem 5%; display:flex; justify-content:space-between; align-items:center; box-shadow:0 2px 15px rgba(0,0,0,0.08);

        }

        .logo { font-size:1.9rem; font-weight:700; color:var(--green); }

        nav a { margin-left:2rem; text-decoration:none; color:#333; font-weight:500; transition:color 0.3s; }

        nav a:hover { color:var(--green); }

        .hero {

            height:100vh; background:linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://picsum.photos/id/1015/1920/1080') center/cover no-repeat;

            display:flex; align-items:center; justify-content:center; text-align:center; color:white;

        }

        .hero-content { max-width:900px; padding:2rem; }

        .hero h1 { font-size:3.8rem; margin-bottom:1rem; }

        .hero p { font-size:1.35rem; margin-bottom:2rem; }

        .btn {

            padding:15px 38px; background:var(--green); color:white; border-radius:50px; text-decoration:none; font-weight:600; display:inline-block; transition:all 0.3s;

        }

        .btn:hover { background:var(--accent); transform:translateY(-4px); }

        section { padding:110px 5%; }

        .section-title { text-align:center; font-size:2.6rem; margin-bottom:3rem; color:var(--dark); }

        .values { display:grid; grid-template-columns:repeat(auto-fit, minmax(280px,1fr)); gap:2.5rem; text-align:center; }

        .value-card { background:white; padding:2.5rem 1.5rem; border-radius:12px; box-shadow:0 8px 25px rgba(0,0,0,0.07); }

        .services { display:grid; grid-template-columns:repeat(auto-fit, minmax(300px,1fr)); gap:2rem; }

        .service-card {

            background:white; border-radius:12px; overflow:hidden; box-shadow:0 10px 30px rgba(0,0,0,0.08); transition:transform 0.3s;

        }

        .service-card:hover { transform:translateY(-12px); }

        .service-card img { width:100%; height:240px; object-fit:cover; }

        .service-card .content { padding:1.8rem; }

        .process { background:#f1f5f0; }

        .steps { display:grid; grid-template-columns:repeat(auto-fit, minmax(260px,1fr)); gap:3rem; }

        .step { text-align:center; }

        .step-num {

            width:75px; height:75px; background:var(--green); color:white; border-radius:50%; margin:0 auto 1.5rem;

            display:flex; align-items:center; justify-content:center; font-size:2rem; font-weight:bold;

        }

        .stats { display:grid; grid-template-columns:repeat(auto-fit, minmax(200px,1fr)); gap:2rem; text-align:center; background:var(--dark); color:white; padding:5rem 5%; border-radius:16px; }

        .contact-section { background:var(--green); color:white; text-align:center; }

        footer { background:var(--dark); color:#ccc; padding:4rem 5% 2rem; text-align:center; }

        .floating-cta {

            position:fixed; bottom:30px; right:30px; background:var(--accent); color:white; padding:16px 32px; border-radius:50px;

            box-shadow:0 6px 20px rgba(0,0,0,0.25); z-index:999; display:flex; align-items:center; gap:10px; font-weight:600;

        }

        @media (max-width:768px) {

            .hero h1 { font-size:2.8rem; }

            nav { display:none; } /* Add hamburger menu if needed */

        }

    </style>

</head>

<body>



